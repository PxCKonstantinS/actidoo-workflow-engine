<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:zeebe="http://camunda.org/schema/zeebe/1.0" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_currency_widget" targetNamespace="http://bpmn.io/schema/bpmn" exporter="hand-written" exporterVersion="1.0" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.4.0">
  <bpmn:collaboration id="Collaboration_currency_widget">
    <bpmn:participant id="Participant_currency_widget" name="Test Flow Currency Widget" processRef="TestFlowCurrencyWidget" />
  </bpmn:collaboration>
  <bpmn:process id="TestFlowCurrencyWidget" name="Test Flow Currency Widget" isExecutable="true">
    <bpmn:laneSet id="LaneSet_currency_widget">
      <bpmn:lane id="InitLaneID" name="Init Lane">
        <bpmn:extensionElements>
          <zeebe:properties>
            <zeebe:property name="initiator" value="true" />
          </zeebe:properties>
        </bpmn:extensionElements>
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>CurrencyForm</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1">
      <bpmn:outgoing>Flow_start_to_form</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="CurrencyForm" name="Enter currency values">
      <bpmn:incoming>Flow_start_to_form</bpmn:incoming>
      <bpmn:outgoing>Flow_form_to_end</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_1">
      <bpmn:incoming>Flow_form_to_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_start_to_form" sourceRef="StartEvent_1" targetRef="CurrencyForm" />
    <bpmn:sequenceFlow id="Flow_form_to_end" sourceRef="CurrencyForm" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_currency_widget">
      <bpmndi:BPMNShape id="Participant_currency_widget_di" bpmnElement="Participant_currency_widget" isHorizontal="true">
        <dc:Bounds x="129" y="79" width="600" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_init_di" bpmnElement="InitLaneID" isHorizontal="true">
        <dc:Bounds x="159" y="79" width="570" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="200" y="160" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="CurrencyForm_di" bpmnElement="CurrencyForm">
        <dc:Bounds x="320" y="138" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="510" y="160" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_to_form_di" bpmnElement="Flow_start_to_form">
        <di:waypoint x="236" y="178" />
        <di:waypoint x="320" y="178" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_form_to_end_di" bpmnElement="Flow_form_to_end">
        <di:waypoint x="420" y="178" />
        <di:waypoint x="510" y="178" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
